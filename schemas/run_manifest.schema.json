{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunManifest",
  "type": "object",
  "required": [
    "exp_id",
    "stage",
    "priority",
    "model_id",
    "seed",
    "backbone_name",
    "layer_mix_mode",
    "router_init_mode",
    "dataset_name",
    "dataset_config",
    "dataset_id",
    "seq_len",
    "token_budget_train",
    "token_budget_val",
    "token_budget_test",
    "start_time",
    "status"
  ],
  "properties": {
    "exp_id": {"type": "string"},
    "stage": {"type": "string", "enum": ["smoke", "probe", "screen", "final", "ablation", "confirm", "optional", "template"]},
    "priority": {"type": "string", "enum": ["must", "should", "optional", "none"]},
    "model_id": {"type": "string"},
    "seed": {"type": "integer"},
    "backbone_name": {"type": "string"},
    "layer_mix_mode": {"type": "string", "enum": ["last_layer", "dense_whs", "sparse_topm", "probe_only"]},
    "router_init_mode": {"type": "string", "enum": ["none", "random", "probe_zscore_top5"]},
    "dataset_name": {"type": "string"},
    "dataset_config": {"type": ["string", "null"]},
    "dataset_id": {"type": "string"},
    "seq_len": {"type": "integer", "minimum": 2},
    "token_budget_train": {"type": "integer", "minimum": 1},
    "token_budget_val": {"type": "integer", "minimum": 1},
    "token_budget_test": {"type": "integer", "minimum": 1},
    "micro_batch_size": {"type": ["integer", "null"], "minimum": 1},
    "grad_accum": {"type": ["integer", "null"], "minimum": 1},
    "nominal_effective_batch_sequences": {"type": ["integer", "null"], "minimum": 1},
    "nominal_tokens_per_optimizer_update": {"type": ["integer", "null"], "minimum": 1},
    "git_commit": {"type": ["string", "null"]},
    "python_version": {"type": ["string", "null"]},
    "torch_version": {"type": ["string", "null"]},
    "cuda_version": {"type": ["string", "null"]},
    "gpu_name": {"type": ["string", "null"]},
    "interpreter_path": {"type": ["string", "null"]},
    "environment_snapshot_path": {"type": ["string", "null"]},
    "start_time": {"type": "string"},
    "end_time": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["running", "paused", "completed", "failed", "aborted"]},
    "resume_count": {"type": ["integer", "null"], "minimum": 0},
    "config_digest": {"type": ["string", "null"]},
    "optimizer_step": {"type": ["integer", "null"], "minimum": 0},
    "micro_step": {"type": ["integer", "null"], "minimum": 0},
    "consumed_tokens": {"type": ["integer", "null"], "minimum": 0},
    "realized_train_tokens": {"type": ["integer", "null"], "minimum": 0},
    "last_checkpoint_path": {"type": ["string", "null"]},
    "last_checkpoint_step": {"type": ["integer", "null"], "minimum": 0},
    "last_checkpoint_micro_step": {"type": ["integer", "null"], "minimum": 0},
    "best_step": {"type": ["integer", "null"], "minimum": 0},
    "best_checkpoint_path": {"type": ["string", "null"]},
    "best_mean_val_nll_h1_h4": {"type": ["number", "null"]},
    "best_mean_val_top1_h2_h4": {"type": ["number", "null"]},
    "checkpoint_selection_rule": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
